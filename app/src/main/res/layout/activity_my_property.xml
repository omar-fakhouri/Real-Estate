<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <include layout="@layout/layout_top_pattern" />

    <RelativeLayout
        android:id="@+id/rlTopSec"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:layout_toStartOf="@+id/clUserImage"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWelcomeBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/urbanistbold"
                android:includeFontPadding="false"
                android:text="@string/lbl_welcome_back"
                android:textColor="@color/subTitle_80"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/urbanistblack"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:text=""
                android:textColor="@color/title"
                android:textSize="24sp" />
        </LinearLayout>


        <include
            android:id="@+id/clUserImage"
            layout="@layout/layout_top_user_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

    </RelativeLayout>

    <include
        android:id="@+id/layState"
        layout="@layout/layout_no_data"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMyProperty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/includeBottomBar"
        android:layout_below="@id/rlTopSec"
        android:padding="10dp"/>


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/ivAddProperty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="110dp"
        app:backgroundTint="@color/back_icon"
        app:elevation="3dp"
        app:fabCustomSize="50dp"
        app:srcCompat="@drawable/ic_add_property"
        app:tint="@color/upload_icon" />
    <include
        android:id="@+id/includeBottomBar"
        layout="@layout/activity_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"/>
    <ProgressBar
        android:id="@+id/progresshome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"
        android:theme="@style/ProgressBar"
        android:visibility="visible"
        />
</RelativeLayout>